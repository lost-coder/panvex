# If you prefer the allow list template instead of the deny list, see community template:
# https://github.com/github/gitignore/blob/main/community/Golang/Go.AllowList.gitignore
#
# Binaries for programs and plugins
*.exe
*.exe~
*.dll
*.so
*.dylib

# Test binary, built with `go test -c`
*.test

# Code coverage profiles and other test artifacts
*.out
coverage.*
*.coverprofile
profile.cov

# Dependency directories (remove the comment below to include it)
# vendor/

# Go workspace file
go.work
go.work.sum

# env file
.env

# Claude Code local config
.claude
.claude.local.md
.superpowers/

# Root-level package files (from plugins, not project)
/package.json
/package-lock.json

# Local git worktrees
.worktrees/

# Local build artifacts
.tmp/
data/
# Stray top-level node_modules (e.g. a vitest .vite cache written with the
# repo root as cwd) — never track it. The real install lives in web/.
/node_modules/
web/node_modules/
web/dist/
web/*.tsbuildinfo
web/*.js
!web/eslint.config.js
web/*.d.ts
cmd/control-plane/.embedded-ui/
cmd/control-plane/ui-dist/
docs/superpowers/

# Local graphify output (per-machine knowledge graph, regenerated via
# `graphify update .`)
graphify-out/

# Editor/IDE
# .idea/
# .vscode/

# Compiled binaries (root-level only)
/agent
/control-plane

# Editor index files (ctags, etc.)
/tags
TAGS

# Private signing key material must never be committed. The public key at
# internal/security/signing_key.pub is the only key that ships in the repo.
*signing*.key
*signing-key*.pem
*.private.pem

# go:generate mirror of deploy/install-agent.sh — canonical source lives in
# deploy/, this copy is recreated by `go generate ./internal/controlplane/server/...`
# before build/test (see install_script.go).
/internal/controlplane/server/install_agent.sh
