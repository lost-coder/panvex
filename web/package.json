{
  "name": "panvex-web",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "node ./node_modules/typescript/bin/tsc --noEmit && node ./node_modules/vite/bin/vite.js build",
    "build:embed": "node ./node_modules/typescript/bin/tsc --noEmit && node ./node_modules/vite/bin/vite.js build --mode embed --outDir ../cmd/control-plane/.embedded-ui --emptyOutDir",
    "preview": "vite preview",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:install": "playwright install --with-deps chromium firefox webkit",
    "test:e2e:integration": "playwright test --config=playwright.integration.config.ts",
    "test:e2e:update-snapshots": "playwright test --update-snapshots",
    "size": "size-limit",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "size-limit": [
    {
      "name": "App entry (gzip)",
      "path": "dist/assets/index-*.js",
      "limit": "25 KB",
      "gzip": true
    },
    {
      "name": "All vendor chunks combined (gzip)",
      "path": "dist/assets/vendor-*.js",
      "limit": "350 KB",
      "gzip": true
    },
    {
      "name": "Largest single page chunk (gzip)",
      "path": "dist/assets/ServerDetailContainer-*.js",
      "limit": "60 KB",
      "gzip": true
    },
    {
      "name": "App stylesheet (gzip)",
      "path": "dist/assets/index-*.css",
      "limit": "50 KB",
      "gzip": true
    }
  ],
  "dependencies": {
    "@fontsource/inter": "^5.2.8",
    "@fontsource/jetbrains-mono": "^5.2.8",
    "@radix-ui/react-collapsible": "^1.1.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-slot": "^1.1.1",
    "@radix-ui/react-tabs": "^1.1.3",
    "@radix-ui/react-toggle": "^1.1.1",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@radix-ui/react-visually-hidden": "^1.1.0",
    "@tanstack/react-query": "^5.99.2",
    "@tanstack/react-router": "^1.168.23",
    "@tanstack/react-virtual": "^3.10.9",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.38.0",
    "i18next": "^26.0.8",
    "lucide-react": "^1.7.0",
    "qrcode.react": "^4.2.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-i18next": "^17.0.4",
    "react-modal-sheet": "^5.6.0",
    "recharts": "^3.8.1",
    "tailwind-merge": "^2.6.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.10.0",
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.50.0",
    "@size-limit/file": "^12.1.0",
    "@storybook/addon-a11y": "^10.3.4",
    "@storybook/react-vite": "^10.3.0",
    "@tailwindcss/vite": "^4.1.16",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@vitejs/plugin-react-swc": "^4.2.2",
    "@vitest/coverage-v8": "^4.1.5",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "jsdom": "^29.0.2",
    "size-limit": "^12.1.0",
    "storybook": "^10.3.0",
    "tailwindcss": "^4.1.16",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.58.0",
    "vite": "^7.2.1",
    "vitest": "^4.1.5"
  }
}
