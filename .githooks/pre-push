#!/bin/bash
# Mirrors key CI checks locally.
#
# Skip paths (fastest → slowest):
#   1. Tag-only push      — auto. The hook reads the refs from stdin and
#      short-circuits when every ref being pushed is under refs/tags/.
#      Rationale: the common release flow is
#        a) push commits, wait for CI,
#        b) push the release tag.
#      Step (b) doesn't change code — re-running the suite adds minutes
#      of wait for no signal. Tags only trigger release.yml on GitHub,
#      which does its own build/sign.
#   2. PANVEX_SKIP_PREPUSH=1  — env override for one-off bypasses.
#   3. `git push --no-verify` — git's built-in escape hatch.
set -e

# ── Tag-only push short-circuit ──────────────────────────────────────────────
# git passes one line per ref on stdin:
#   <local-ref> <local-sha> <remote-ref> <remote-sha>
# Read them all, then decide. If *every* local-ref starts with refs/tags/,
# skip the suite. If stdin is empty (rare, e.g. dry-run), fall through.
any_ref=0
any_non_tag=0
while read -r local_ref _local_sha _remote_ref _remote_sha; do
    [ -z "$local_ref" ] && continue
    any_ref=1
    case "$local_ref" in
        refs/tags/*) ;;
        *) any_non_tag=1 ;;
    esac
done

if [ "$any_ref" = 1 ] && [ "$any_non_tag" = 0 ]; then
    echo "=== Pre-push: tag-only push — skipping CI mirror checks ==="
    exit 0
fi

# ── Env override ─────────────────────────────────────────────────────────────
if [ "${PANVEX_SKIP_PREPUSH:-}" = "1" ]; then
    echo "=== Pre-push: PANVEX_SKIP_PREPUSH=1 — skipping CI mirror checks ==="
    exit 0
fi

echo "=== Pre-push: Mirror install-agent.sh into server package ==="
# //go:embed cannot reference files outside the package, so we mirror
# deploy/install-agent.sh into internal/controlplane/server/ before any
# Go build/test/lint. See internal/controlplane/server/install_script.go.
go generate ./internal/controlplane/server/...

echo "=== Pre-push: Go lint ==="
~/go/bin/golangci-lint run ./...

echo "=== Pre-push: Settings codegen drift ==="
go generate ./internal/controlplane/settings/... >/dev/null 2>&1
if ! git diff --quiet -- internal/controlplane/settings/gen/schema.json docs/settings/reference.md docs/settings/example.config.toml; then
    echo "!!! Settings codegen drift; run 'make gen-settings' and commit."
    exit 1
fi

echo "=== Pre-push: Go tests (race, loadtest excluded) ==="
# The internal/loadtest scenarios spawn ~100 concurrent Argon2id verifies
# (~96 MiB each) and ~200-agent enrolls; under -race the working set tips
# past 22 GB RSS, which OOM-kills the test on memory-constrained dev hosts
# (e.g. WSL2 with default RAM cap). CI splits the same way — see
# .github/workflows/ci.yml jobs `test-go-race` vs `test-go-loadtest`.
RACE_PKGS=$(go list ./... | grep -v '^github.com/lost-coder/panvex/internal/loadtest$')
go test -race -count=1 $RACE_PKGS

echo "=== Pre-push: Go tests (loadtest, no -race) ==="
go test -count=1 ./internal/loadtest/...

echo "=== Pre-push: Go vulnerability scan ==="
if command -v govulncheck >/dev/null 2>&1; then
    govulncheck ./...
elif [ -x "$HOME/go/bin/govulncheck" ]; then
    "$HOME/go/bin/govulncheck" ./...
else
    echo "!!! govulncheck not installed. Run: make install-tools"
    exit 1
fi

echo "=== Pre-push: Frontend type-check + build ==="
cd web
npm run build

echo "=== Pre-push: Frontend lint ==="
npm run lint

echo "=== Pre-push: Frontend state tests (node --test) ==="
npm run test:state

echo "=== Pre-push: Frontend audit (moderate severity) ==="
# L-22: stay in lock-step with the CI workflow's --audit-level=moderate
# so a hook-passing push cannot still fail the equivalent CI step.
npm audit --audit-level=moderate

echo "=== Pre-push: all checks passed ==="
