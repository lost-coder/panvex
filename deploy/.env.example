# Copy this file to .env and customize for your deployment.
# Do not commit .env to version control.
POSTGRES_USER=panvex
POSTGRES_PASSWORD=change-me-in-production
POSTGRES_DB=panvex

# --- Operator escape hatches (leave unset unless you know you need them) ---

# Permit prod boot with a public bind and an empty PANVEX_TRUSTED_PROXY_CIDRS.
# Declares "no reverse proxy in front of the panel, RemoteAddr is the real
# client IP". Without this, PANVEX_ENV=production refuses to start.
# PANVEX_ALLOW_DIRECT_EXPOSURE=1

# Permit persisting the CA private key unencrypted when PANVEX_ENCRYPTION_KEY
# is empty. Dev/test-only escape hatch; production normally refuses to
# persist an unencrypted CA key.
# PANVEX_ALLOW_PLAINTEXT_CA=1

# Permit the `self-update -token` flag, which leaks the GitHub token via
# /proc/<pid>/cmdline. Prefer -token-file or the GITHUB_TOKEN env var instead.
# PANVEX_SELF_UPDATE_ALLOW_INSECURE_TOKEN_FLAG=1
